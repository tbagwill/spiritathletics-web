generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  role         UserRole      @default(CUSTOMER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  passwordHash String?
  accounts     Account[]
  auditLogs    AuditLog[]    @relation("AuditLogActor")
  bookings     Booking[]
  coachProfile CoachProfile?
  sessions     Session[]
}

model CoachProfile {
  id                     String                  @id @default(cuid())
  userId                 String                  @unique
  bio                    String?
  specialties            String[]
  isActive               Boolean                 @default(true)
  availabilityExceptions AvailabilityException[]
  availabilityRules      AvailabilityRule[]
  bookings               Booking[]
  user                   User                    @relation(fields: [userId], references: [id])
  settings               CoachSettings?
  NotificationPreference NotificationPreference?
  services               Service[]
}

model Service {
  id              String          @id @default(cuid())
  coachId         String?
  type            ServiceType
  title           String
  description     String
  durationMinutes Int?
  basePriceCents  Int
  isActive        Boolean         @default(true)
  bookings        Booking[]
  classTemplates  ClassTemplate[]
  coach           CoachProfile?   @relation(fields: [coachId], references: [id])
}

model AvailabilityRule {
  id                 String         @id @default(cuid())
  coachId            String
  ruleType           WeeklyRuleType
  byDay              String[]
  startTimeMinutes   Int
  endTimeMinutes     Int
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  slotIntervalMinutes Int           @default(30)
  createdAt          DateTime       @default(now())
  coach              CoachProfile   @relation(fields: [coachId], references: [id])
}

model AvailabilityException {
  id          String       @id @default(cuid())
  coachId     String
  date        DateTime
  isAvailable Boolean
  reason      String?
  createdAt   DateTime     @default(now())
  coach       CoachProfile @relation(fields: [coachId], references: [id])
}

model ClassTemplate {
  id               String            @id @default(cuid())
  serviceId        String
  weekday          Int
  startTimeMinutes Int
  capacity         Int
  location         String?
  isActive         Boolean           @default(true)
  startDate        DateTime?
  endDate          DateTime?
  occurrences      ClassOccurrence[]
  service          Service           @relation(fields: [serviceId], references: [id])
}

model ClassOccurrence {
  id               String           @id @default(cuid())
  classTemplateId  String
  startDateTimeUTC DateTime
  capacity         Int
  status           OccurrenceStatus @default(SCHEDULED)
  bookings         Booking[]
  classTemplate    ClassTemplate    @relation(fields: [classTemplateId], references: [id])

  @@unique([classTemplateId, startDateTimeUTC])
}

model Booking {
  id                   String           @id @default(cuid())
  type                 ServiceType
  status               BookingStatus    @default(CONFIRMED)
  privateKind          PrivateKind?
  numAthletes          Int              @default(1)
  customerName         String
  customerEmail        String
  athleteName          String
  notes                String?
  coachId              String?
  serviceId            String
  classOccurrenceId    String?
  startDateTimeUTC     DateTime
  endDateTimeUTC       DateTime
  priceCents           Int
  perAthletePriceCents Int?
  cancellationToken    String           @unique
  cancelledAt          DateTime?
  createdAt            DateTime         @default(now())
  customerUserId       String?
  stripeSessionId      String?
  paymentMethod        PaymentMethod    @default(CARD)
  approvalStatus       ApprovalStatus   @default(APPROVED)
  approvalToken        String?          @unique
  approvedAt           DateTime?
  autoExpireAt         DateTime?
  denialReason         String?
  deniedAt             DateTime?
  reminderSentAt       DateTime?
  isManualBlock        Boolean          @default(false)
  requestedAt          DateTime         @default(now())
  classOccurrence      ClassOccurrence? @relation(fields: [classOccurrenceId], references: [id])
  coach                CoachProfile?    @relation(fields: [coachId], references: [id])
  customerUser         User?            @relation(fields: [customerUserId], references: [id])
  service              Service          @relation(fields: [serviceId], references: [id])

  @@index([approvalStatus, coachId])
  @@index([autoExpireAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String
  meta        Json
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditLogActor", fields: [actorUserId], references: [id])
}

model CancellationPolicy {
  id             String @id @default(cuid())
  minHoursNotice Int
}

model CoachSettings {
  id                    String       @id @default(cuid())
  coachId               String       @unique
  mustApproveRequests   Boolean      @default(false)
  alertEmails           String[]     @default([])
  emailBookingConfirmed Boolean      @default(true)
  emailBookingCancelled Boolean      @default(true)
  dailyAgendaEmail      Boolean      @default(false)
  canManageShop         Boolean      @default(false)
  coach                 CoachProfile @relation(fields: [coachId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ShopCampaign {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  description  String?
  heroImageUrl String?
  startsAt     DateTime
  endsAt       DateTime
  status       CampaignStatus @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  orders       ShopOrder[]
  products     ShopProduct[]
}

model ShopProduct {
  id             String          @id @default(cuid())
  campaignId     String
  name           String
  slug           String
  basePrice      Int
  description    String?
  imageUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  imageUrls      String[]        @default([])
  sizingChartUrl String?
  sizes          ProductSize[]
  orderItems     ShopOrderItem[]
  campaign       ShopCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, slug])
}

model ProductSize {
  id         String          @id @default(cuid())
  productId  String
  label      String
  priceDelta Int             @default(0)
  product    ShopProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems ShopOrderItem[]

  @@unique([productId, label])
}

model ShopOrder {
  id              String          @id @default(cuid())
  campaignId      String
  email           String
  customerName    String?
  subtotalCents   Int
  totalCents      Int
  stripePaymentId String?
  status          OrderStatus     @default(PAID)
  createdAt       DateTime        @default(now())
  campaign        ShopCampaign    @relation(fields: [campaignId], references: [id])
  lineItems       ShopOrderItem[]
}

model ShopOrderItem {
  id        String      @id @default(cuid())
  orderId   String
  productId String
  sizeId    String
  quantity  Int         @default(1)
  unitPrice Int
  lineTotal Int
  order     ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   ShopProduct @relation(fields: [productId], references: [id])
  size      ProductSize @relation(fields: [sizeId], references: [id])
}

model ErrorLog {
  id         String     @id
  level      ErrorLevel
  message    String
  stack      String?
  context    Json?
  userId     String?
  url        String?
  userAgent  String?
  timestamp  DateTime   @default(now())
  resolved   Boolean    @default(false)
  resolvedAt DateTime?
  resolvedBy String?

  @@index([level, timestamp])
  @@index([resolved, timestamp])
}

model NotificationPreference {
  id             String       @id
  coachId        String       @unique
  emailOnRequest Boolean      @default(true)
  emailReminder  Boolean      @default(true)
  reminderHours  Int          @default(6)
  dashboardBadge Boolean      @default(true)
  soundAlert     Boolean      @default(false)
  dailySummary   Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  CoachProfile   CoachProfile @relation(fields: [coachId], references: [id])
}

model NotificationQueue {
  id           String           @id
  type         NotificationType
  recipientId  String
  data         Json
  status       QueueStatus      @default(PENDING)
  attempts     Int              @default(0)
  lastAttempt  DateTime?
  processedAt  DateTime?
  error        String?
  scheduledFor DateTime         @default(now())
  createdAt    DateTime         @default(now())

  @@index([recipientId])
  @@index([status, scheduledFor])
}

model PerformanceLog {
  id         String   @id
  route      String
  method     String
  statusCode Int
  duration   Int
  timestamp  DateTime @default(now())

  @@index([duration])
  @@index([route, timestamp])
}

model SystemMetric {
  id        String     @id
  type      MetricType
  name      String
  value     Float
  metadata  Json?
  timestamp DateTime   @default(now())

  @@index([name, timestamp])
  @@index([type, timestamp])
}

model UploadedImage {
  id        String   @id
  url       String
  publicId  String?
  type      String
  variants  Json?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

// Clinics / Special Events
model Clinic {
  id              String               @id @default(cuid())
  title           String
  slug            String               @unique
  description     String
  dateTimeUTC     DateTime
  endDateTimeUTC  DateTime
  durationMinutes Int
  priceCents      Int
  capacity        Int
  location        String?
  imageUrl        String?
  isActive        Boolean              @default(true)
  isFeatured      Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  registrations   ClinicRegistration[]
}

model ClinicRegistration {
  id               String        @id @default(cuid())
  clinicId         String
  customerName     String
  customerEmail    String
  athleteFirstName String
  stripeSessionId  String?
  paymentMethod    PaymentMethod @default(CARD)
  status           BookingStatus @default(CONFIRMED)
  cancelledAt      DateTime?
  createdAt        DateTime      @default(now())
  clinic           Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  COACH
  CUSTOMER
}

enum ServiceType {
  PRIVATE
  CLASS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum OccurrenceStatus {
  SCHEDULED
  CANCELLED
}

enum WeeklyRuleType {
  WEEKLY
}

enum PrivateKind {
  SOLO
  SEMI_PRIVATE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
  FULFILLED
  CANCELED
}

enum OrderStatus {
  PAID
  REFUNDED
  CANCELED
}

enum PaymentMethod {
  CARD
  CASH
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  CANCELLED
}

enum ErrorLevel {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum MetricType {
  API_LATENCY
  DATABASE_QUERY
  MEMORY_USAGE
  CACHE_HIT_RATE
  BOOKING_RATE
  ERROR_RATE
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_REMINDER
  BOOKING_APPROVED
  BOOKING_DENIED
  BOOKING_EXPIRED
  DAILY_SUMMARY
}

enum QueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Waiver {
  id                String   @id @default(cuid())
  athleteFirstName  String
  athleteLastName   String
  parentFirstName   String
  parentLastName    String
  parentEmail       String
  signatureDataUrl  String
  waiverVersion     String   @default("1.0")
  signedAt          DateTime @default(now())
  ipAddress         String?
  userAgent         String?
  pdfUrl            String?
  createdAt         DateTime @default(now())

  @@index([parentEmail])
  @@index([athleteLastName, athleteFirstName])
}
